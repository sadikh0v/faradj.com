# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# Защита .env
<Files ".env">
  Require all denied
</Files>
<Files "*.env">
  Require all denied
</Files>

<IfModule mod_headers.c>
  <FilesMatch "\.(php)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^storage/ - [F,L]
  RewriteRule ^thank-you$ thank-you.php [L,QSA]
  RewriteRule ^auth$ /admin/login [R=302,L]
  RewriteRule ^login$ /admin/login [R=302,L]
  RewriteRule ^sitemap\.xml$ sitemap.php [L]
  RewriteRule ^api/instagram$ api/instagram.php [L]
  RewriteRule ^lang$ index.php [L]
  RewriteRule ^admin/?$ admin/index.php [L]
  RewriteRule ^admin/(.*)$ admin/index.php?path=$1 [L,QSA]
</IfModule>

ErrorDocument 404 /404.php
